@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Vulkan)
find_dependency(hwy CONFIG)
find_dependency(yaml-cpp CONFIG)
find_dependency(CLI11 CONFIG)
find_dependency(fmt CONFIG)
if(@OA_BUILD_CRYPTO@)
	find_dependency(liboqs CONFIG)
endif()
if(@OA_PACKAGE_NEEDS_UTF8PROC@)
	find_dependency(utf8proc CONFIG)
endif()
if("@OA_WEBP_DEPENDENCY_MODE@" STREQUAL "CMake")
	find_dependency(WebP CONFIG)
elseif("@OA_WEBP_DEPENDENCY_MODE@" STREQUAL "PkgConfig")
	find_dependency(PkgConfig)
	pkg_check_modules(OA_WEBP REQUIRED IMPORTED_TARGET libwebp)
endif()
if(@OA_PACKAGE_NEEDS_SDL3@)
	find_dependency(SDL3 CONFIG)
endif()
if(@OA_PACKAGE_NEEDS_PIPEWIRE_CAPTURE@)
	find_dependency(PkgConfig)
	pkg_check_modules(OA_PIPEWIRE REQUIRED IMPORTED_TARGET libpipewire-0.3)
	pkg_check_modules(OA_LIBPORTAL REQUIRED IMPORTED_TARGET libportal)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/oa-targets.cmake")

# Slang shader module search paths for consumer repos
# Use: slangc -I ${OA_SLANG_UMBRELLA_PATH} -I ${OA_SLANG_MODULE_PATH} ...
# Umbrella: include/Oa/Core/Math.slang — `import Math;`
# Importable modules (no entry points): lib/Oa/Core/Shader/Compute/Math/ — Storage, Activations, …
# Core matrix entry shaders (sources): lib/Oa/Core/Shader/Compute/Matrix/ — Matmul, Transpose, …
get_filename_component(_oa_prefix "${CMAKE_CURRENT_LIST_DIR}/../../.." ABSOLUTE)
set(OA_SLANG_MODULE_PATH "${_oa_prefix}/lib/Oa/Core/Shader/Compute/Math"
	CACHE PATH "Path to oa Slang importable math modules (Kernel/Math/*.slang)")
set(OA_SLANG_KERNEL_MATRIX_PATH "${_oa_prefix}/lib/Oa/Core/Shader/Compute/Matrix"
	CACHE PATH "Path to oa core matrix compute .slang entry points (optional -I for local compiles)")
set(OA_SLANG_UMBRELLA_PATH "${_oa_prefix}/include/Oa/Core"
	CACHE PATH "Path to oa Slang umbrella module (Math.slang)")
